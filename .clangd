If:
  PathExclude: [third_party/.*]

CompileFlags:
  # 使用项目根目录的 compile_commands.json
  CompilationDatabase: build

  Add:
    # C++23 标准
    - "-std=c++23"
    
    # 启用协程支持
    - "-fcoroutines"
    
    # 添加常用警告
    - "-Wall"
    - "-Wextra"
    
    # C++ 特定警告控制
    - "-Wno-unused-parameter"
    - "-Wno-missing-field-initializers"

    # MSVC 兼容模式
    - "--target=x86_64-pc-windows-msvc"
    - "-fms-compatibility"
    - "-fms-extensions"
    - "-fdelayed-template-parsing"
    
  Remove:
    # 移除 CMake 生成的不兼容模块参数
    - "-fmodules-ts"
    - "-fmodule-mapper=*"
    - "-fdeps-format=*"
    - "-fcoroutines-ts"
    - "-ftemplate-backtrace-limit=*"
    - "-fmacro-backtrace-limit=*"
    - "/EHsc"
    - "-wd*"

# 诊断配置
Diagnostics:
  # 抑制常见的无害警告
  Suppress:
    - "unused-parameter"
    - "misc-unused-parameters"

# 代码补全配置
Completion:
  AllScopes: Yes

# 索引配置
Index:
  Background: Build

